# frozen_string_literal: true

# !/usr/bin/env ruby

require 'dotenv/load'
require 'tty-spinner'
require 'pastel'

# Parse --config path/to/custom.yml before loading config
if (idx = ARGV.index('--config'))
  config_path = ARGV[idx + 1]
  raise '--config requires a path argument' if config_path.nil?

  ARGV.slice!(idx, 2)
  ENV['SHOEGAZEGAZER_CONFIG'] = File.expand_path(config_path)
end

require_relative '../lib/config'
require_relative '../lib/scraper'
require_relative '../lib/lastfm'
require_relative '../lib/scorer'
require_relative '../lib/formatter'

pastel  = Pastel.new
spinner = TTY::Spinner.new('[:spinner] :title', format: :dots)

# Step 1 — fetch from all sources + dedup
spinner.update(title: 'Fetching new releases...')
spinner.auto_spin
aoty_albums  = Scraper.fetch_aoty
mb_albums    = Scraper.fetch_musicbrainz
albums       = Scraper.dedup(aoty_albums + mb_albums)
spinner.success(pastel.green("done (#{aoty_albums.size} AOTY + #{mb_albums.size} MusicBrainz = #{albums.size} unique)"))

# Step 2 — filter low-rated albums
albums = albums.reject { |a| !a[:score].nil? && a[:score] < TASTE_PROFILE[:min_score] }

# Step 3 — enrich tags + score
spinner = TTY::Spinner.new('[:spinner] :title', format: :dots)
spinner.update(title: 'Scoring against your taste profile...')
spinner.auto_spin

scored = albums.map do |album|
  album_tags = LastFm.album_tags(album[:artist], album[:title])
  similarity = Scorer.score(
    artist: album[:artist],
    title: album[:title],
    tags: album_tags,
    metacritic_score: album[:score]
  )
  album.merge(
    similarity_score: similarity,
    tags: album_tags,
    apple_music_url: Scraper.apple_music_url(album[:artist], album[:title])
  )
end

spinner.success(pastel.green('done'))

# Step 4 — sort, take top 20
results = scored.sort_by { |a| -a[:similarity_score] }.first(20)

puts
Formatter.print_results(results)

puts
puts pastel.dim("Powered by Last.fm • Album of the Year • MusicBrainz • #{Time.now.strftime('%A, %B %d %Y')}")
